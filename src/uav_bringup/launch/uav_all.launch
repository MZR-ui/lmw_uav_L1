<launch>
    <!-- 
        UAV 系统主启动文件
        包含所有功能包的 launch 文件，一键启动全部节点。
        各子 launch 文件位于各自功能包的 launch 目录中。
    -->

    <!-- 包含 MSP 接口节点（飞控通信） -->
    <include file="$(find msp_interface)/launch/msp_interface.launch">
        <!-- 如需覆盖默认参数，可在此添加 arg 传递，例如：
        <arg name="port" value="/dev/ttyUSB0" />
        <arg name="baud" value="115200" />
        -->
    </include>

    <!-- 以下两个节点暂时屏蔽
    <include file="$(find gimbal_control_serial)/launch/gimbal_control.launch">
        <arg name="some_param" value="value" />
    </include>

    <include file="$(find sensing)/launch/realsense.launch">
        <arg name="enable_pointcloud" value="false" />
    </include>
    -->

    <!-- 如果需要节点间话题重映射，可以在此直接启动节点并 remap，但通常在各子 launch 中处理更合适。
         若全局需统一话题名称，也可在 include 后使用 remap 标签（需放在 node 标签内）。此处不添加示例。
    -->

    <!-- 可以额外添加全局参数服务器参数 -->
    <!-- <param name="use_sim_time" value="false" /> -->

</launch>